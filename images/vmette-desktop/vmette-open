#!/bin/sh
# vmette-open URL — open a single URL (or file) in the desktop's browser.
#
# The desktop agent's `navigate` action execs this with exactly one argument
# and no shell, so the URL is never word-split or interpreted. Keeping the
# browser choice here (not in the agent) lets a custom desktop image ship a
# different browser without touching the agent: drop in your own vmette-open.
set -eu

target=${1:-about:blank}

if command -v chromium >/dev/null 2>&1; then
    exec chromium "$target"
elif command -v chromium-browser >/dev/null 2>&1; then
    exec chromium-browser "$target"
elif command -v firefox >/dev/null 2>&1; then
    exec firefox "$target"
elif command -v xdg-open >/dev/null 2>&1; then
    exec xdg-open "$target"
fi

echo "vmette-open: no browser found on PATH" >&2
exit 127
